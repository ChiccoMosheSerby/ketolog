# Copy this file to ".env" and fill in real values. NEVER commit .env.

# MongoDB Atlas connection string (Database -> Connect -> Drivers)
# Looks like: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/ketolog?retryWrites=true&w=majority
MONGODB_URI=

# Anthropic API key (console.anthropic.com -> API Keys). Starts with sk-ant-
ANTHROPIC_API_KEY=

# Secret used to sign login tokens. Use any long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Port the API listens on (the React dev server proxies to this)
PORT=4000

# Which Claude model to use for nutrition estimation (the log calculator)
CLAUDE_MODEL=claude-opus-4-8

# Which Claude model the conversational keto assistant uses
CHAT_MODEL=claude-opus-4-8
