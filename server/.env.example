# Copy this file to ".env" and fill in real values. NEVER commit .env.

# MongoDB Atlas connection string (Database -> Connect -> Drivers)
# Looks like: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/ketolog?retryWrites=true&w=majority
MONGODB_URI=

# Anthropic API key (console.anthropic.com -> API Keys). Starts with sk-ant-
ANTHROPIC_API_KEY=

# OpenAI API key — used ONLY for voice-input transcription (speech-to-text).
# platform.openai.com -> API Keys. Starts with sk-. Leave blank to disable the
# mic button; the app still works fully by typing.
OPENAI_API_KEY=

# Which OpenAI model transcribes voice input. whisper-1 honours the Hebrew
# language + vocabulary hints best for short clips; gpt-4o-transcribe drifts.
TRANSCRIBE_MODEL=whisper-1

# Secret used to sign login tokens. Use any long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Port the API listens on (the React dev server proxies to this)
PORT=4000

# Comma-separated list of origins allowed to call the API cross-origin. The
# client is served from the same origin as the API, so this is usually not
# needed; defaults to https://ketolog.onrender.com (plus localhost in dev). Set
# only if you host the client on a different domain.
CORS_ORIGINS=

# Which Claude model to use for nutrition estimation (the log calculator)
CLAUDE_MODEL=claude-opus-4-8

# Which Claude model the conversational keto assistant uses
CHAT_MODEL=claude-opus-4-8

# --- New-user approval ---------------------------------------------------
# New sign-ups (except the built-in admin emails) are created as "pending" and
# can't sign in until approved via a link emailed to ADMIN_EMAIL.
ADMIN_EMAIL=chiccomoshe@gmail.com

# Optional override for the base URL used in the approval link. Leave BLANK to
# use the automatic default: localhost in development, the deployed Render URL
# (https://ketolog.onrender.com) when NODE_ENV=production. Only set this to
# force a different origin. No trailing slash.
APP_URL=

# --- Email delivery ------------------------------------------------------
# Two backends. If BREVO_API_KEY is set it wins (HTTPS API — works on hosts
# that block outbound SMTP, e.g. Render's free tier). Otherwise SMTP is used.
# If neither is set, the link is logged to the server console (fine for dev).

# Brevo (brevo.com) HTTP email API — the production path.
#   1. Create a free account (300 emails/day).
#   2. Senders, Domains & Dedicated IPs -> verify a single sender email (no domain needed).
#   3. SMTP & API -> API Keys -> create one (starts with 'xkeysib-').
# BREVO_SENDER_EMAIL must be a verified sender; defaults to SMTP_FROM/SMTP_USER/ADMIN_EMAIL.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=KetoLog

# SMTP settings — used only when BREVO_API_KEY is blank (e.g. local dev; Gmail
# SMTP is blocked on Render's free tier). Gmail example: host smtp.gmail.com,
# port 465, user = the gmail address, pass = a Google "App password".
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# Optional From header; defaults to SMTP_USER, then ADMIN_EMAIL.
SMTP_FROM=

# --- WhatsApp meal logging (Twilio) --------------------------------------
# Text a meal description to the WhatsApp bot and it calculates + logs it to
# today's journal, then replies with a receipt. Link your number in the app:
# menu → "מספר WhatsApp". Leave these blank to disable the webhook entirely.
#
# From console.twilio.com: Account SID + Auth Token. TWILIO_WHATSAPP_FROM is the
# bot's WhatsApp sender in 'whatsapp:+<E.164>' form — for the free sandbox it is
# whatsapp:+14155238886 (and each tester first sends the sandbox join code to it).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Recommended: an API key (Console → Account → API keys & tokens → Create).
# Twilio auto-resets the account Auth Token after inactivity, which silently
# breaks outbound sends; an API key stays valid until revoked. When both are
# set, outbound messages use the key. TWILIO_AUTH_TOKEN is still required — it's
# what validates Twilio's inbound webhook signatures. KeySid starts with 'SK'.
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# Point Twilio's "When a message comes in" webhook (Messaging → your WhatsApp
# sender / sandbox settings) at:  <this server>/api/whatsapp/inbound  (POST).
# Set WHATSAPP_WEBHOOK_URL to that exact public URL so request-signature
# validation matches. Leave blank to reconstruct it from the incoming request
# (works behind Render's proxy, but the explicit value removes any ambiguity).
WHATSAPP_WEBHOOK_URL=
